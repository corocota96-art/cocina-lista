---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Artículos relacionados: primero los que comparten más etiquetas,
// y si no, los más recientes. Máximo 3.
const all = await getCollection('blog');
const currentTags = post.data.tags ?? [];
const relatedPosts = all
	.filter((p) => p.id !== post.id)
	.map((p) => ({
		post: p,
		shared: (p.data.tags ?? []).filter((t) => currentTags.includes(t)).length,
	}))
	.sort((a, b) => b.shared - a.shared || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
	.slice(0, 3)
	.map((x) => x.post);
---

<BlogPost {...post.data} relatedPosts={relatedPosts}>
	<Content />
</BlogPost>
