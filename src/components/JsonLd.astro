---
// Inserta datos estructurados (JSON-LD) de forma segura.
// Escapamos "<" para evitar que el contenido pueda cerrar el <script>.
interface Props {
	data: unknown;
}
const { data } = Astro.props;
const json = JSON.stringify(data).replace(/</g, '\\u003c');
---

<script type="application/ld+json" is:inline set:html={json}></script>
