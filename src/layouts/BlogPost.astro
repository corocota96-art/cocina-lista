---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_TITLE, AUTHOR_NAME } from '../consts';
import { withBase } from '../lib/links';

type Props = CollectionEntry<'blog'>['data'] & {
	relatedPosts?: CollectionEntry<'blog'>[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	affiliate,
	relatedPosts = [],
} = Astro.props;

// URLs absolutas para los datos estructurados
const postUrl = new URL(Astro.url.pathname, Astro.site).href;
const homeUrl = new URL(import.meta.env.BASE_URL, Astro.site).href;
const blogUrl = new URL(withBase('blog'), Astro.site).href;
const imageUrl = heroImage ? new URL(heroImage.src, Astro.site).href : undefined;

const articleGraph = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'BlogPosting',
			'@id': `${postUrl}#article`,
			headline: title,
			description,
			inLanguage: 'es-ES',
			datePublished: pubDate.toISOString(),
			dateModified: (updatedDate ?? pubDate).toISOString(),
			author: { '@id': `${homeUrl}#author` },
			publisher: { '@id': `${homeUrl}#org` },
			mainEntityOfPage: postUrl,
			isPartOf: { '@id': `${homeUrl}#website` },
			...(imageUrl ? { image: imageUrl } : {}),
			...(tags.length ? { keywords: tags.join(', ') } : {}),
		},
		{
			'@type': 'BreadcrumbList',
			'@id': `${postUrl}#breadcrumb`,
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Inicio', item: homeUrl },
				{ '@type': 'ListItem', position: 2, name: 'Recetas', item: blogUrl },
				{ '@type': 'ListItem', position: 3, name: title, item: postUrl },
			],
		},
	],
};
---

<html lang="es">
	<head>
		<BaseHead title={`${title} · ${SITE_TITLE}`} description={description} image={heroImage} />
		<JsonLd data={articleGraph} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.breadcrumb {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
				text-align: center;
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.title {
				margin-bottom: 1em;
				padding: 0.5em 0 1em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.byline {
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				justify-content: center;
				margin-bottom: 0.5em;
			}
			.tag {
				font-size: 0.8em;
				color: rgb(var(--gray-dark));
				background: rgb(var(--gray-light));
				padding: 0.15em 0.7em;
				border-radius: 999px;
			}
			.relacionados {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto 0;
				padding: 1.5em 1em 0;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.relacionados h2 {
				font-size: 1.5em;
			}
			.relacionados ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.relacionados li {
				margin-bottom: 0.6em;
			}
			.relacionados a {
				text-decoration: none;
				font-weight: 600;
			}
			.relacionados a:hover {
				text-decoration: underline;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<nav class="breadcrumb" aria-label="Migas de pan">
						<a href={withBase('/')}>Inicio</a> ›
						<a href={withBase('blog')}>Recetas</a> › <span>{title}</span>
					</nav>
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Actualizado el <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<p class="byline">Por {AUTHOR_NAME}</p>
						<h1>{title}</h1>
						{
							tags.length > 0 && (
								<div class="tags">
									{tags.map((t) => (
										<span class="tag">#{t}</span>
									))}
								</div>
							)
						}
						<hr />
					</div>
					{affiliate && <AffiliateDisclosure />}
					<slot />
				</div>
			</article>
			{
				relatedPosts.length > 0 && (
					<section class="relacionados">
						<h2>Sigue leyendo</h2>
						<ul>
							{relatedPosts.map((rp) => (
								<li>
									<a href={withBase(`blog/${rp.id}/`)}>{rp.data.title}</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
